# PostgreSQL (use docker-compose up to start a local instance)
DATABASE_URL="postgresql://daydesk:daydesk@localhost:5432/daydesk"
DIRECT_URL="postgresql://daydesk:daydesk@localhost:5432/daydesk"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# Auth0 Configuration
APP_BASE_URL=http://localhost:3000

# Minimum time (ms) to show skeleton loading placeholders before revealing content.
# Prevents flickering when data loads too quickly. Set to 0 to disable.
NEXT_PUBLIC_SKELETON_MIN_MS=300
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_SECRET=generate-with-openssl-rand-hex-32
