# PostgreSQL (use docker-compose up to start a local instance)
DATABASE_URL="postgresql://daydesk:daydesk@localhost:5432/daydesk"
DIRECT_URL="postgresql://daydesk:daydesk@localhost:5432/daydesk"
NEXTAUTH_URL="http://localhost:3000"
# 64 character random string to encrypt the session cookie
# generate your own secret using `openssl rand -hex 32`
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# OAuth / OIDC Configuration (works with any OIDC provider: Auth0, Keycloak, Okta, Azure AD, etc.)
APP_BASE_URL=http://localhost:3000

# Minimum time (ms) to show skeleton loading placeholders before revealing content.
# Prevents flickering when data loads too quickly. Set to 0 to disable.
NEXT_PUBLIC_SKELETON_MIN_MS=300

# Required — your OIDC provider's issuer URL (must expose /.well-known/openid-configuration)
OAUTH_ISSUER=https://your-tenant.auth0.com
OAUTH_CLIENT_ID=your-oauth-client-id
OAUTH_CLIENT_SECRET=your-oauth-client-secret

# Optional — provider logout URL for RP-initiated logout
# Auth0 example: https://your-tenant.auth0.com/v2/logout?client_id=YOUR_CLIENT_ID
# OAUTH_LOGOUT_URL=

# Web Push Notifications (optional)
# Generate VAPID keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
PUSH_API_SECRET=generate-with-openssl-rand-hex-32
